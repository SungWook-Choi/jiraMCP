{
  "name": "qwen-jira-mcp",
  "version": "0.1.0",
  "description": "CLI, local API server, and MCP entrypoints for the qwen Jira MVP",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SungWook-Choi/jiraMCP.git"
  },
  "homepage": "https://github.com/SungWook-Choi/jiraMCP#readme",
  "bugs": {
    "url": "https://github.com/SungWook-Choi/jiraMCP/issues"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    ".env.example"
  ],
  "bin": {
    "qwen-jira": "bin/qwen-jira.js",
    "qwen-jira-server": "bin/qwen-jira-server.js",
    "qwen-jira-mcp": "bin/qwen-jira-mcp.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "jira",
    "nestjs",
    "cli",
    "mcp",
    "server"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "start:api": "node dist/server-entry.js",
    "start:server": "node dist/server-entry.js",
    "start:cli": "node dist/cli-entry.js",
    "start:mcp": "node dist/mcp-entry.js",
    "start:dev:api": "node --enable-source-maps --loader ts-node/esm src/server-entry.ts",
    "start:dev:cli": "node --enable-source-maps --loader ts-node/esm src/cli-entry.ts",
    "start:dev:mcp": "node --enable-source-maps --loader ts-node/esm src/mcp-entry.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
